{% import 'components/form/fields_macros.html.twig' as fields %}
{% import 'components/form/basic_inputs_macros.html.twig' as inputs %}

<div class="asset">

	<div class="card-body d-flex flex-wrap">
		<div class="col-12 col-xxl-12 flex-column">
			<div class="d-flex flex-row flex-wrap flex-xl-nowrap">
				<div class="row flex-row align-items-start flex-grow-1">
					<div class="row flex-row">
						{% block form_fields %}

							{% if item.isNewItem() %}
								{{ inputs.hidden('users_id', current_users_id) }}
								{{ fields.textField('name', item.fields['name'], __('Report Name'), {
                                        required:  true
                                }) }}
							{% else %}
								{% set name_field %}
								<span class="fw-bold">{{ item.fields['name'] }}</span>
								<input type="hidden" name="name" value="{{ item.fields['name'] }}"/>
								{% endset %}
								{{ fields.htmlField(
                                    'name',
                                    name_field,
                                    __('Report Name')
                                ) }}
							{% endif %}

							{{ fields.textareaField('desc', item.fields['desc'], __('Description')) }}

							{# Status #}
							{{ fields.dropdownArrayField('status', item.fields['status'], {
                                    (constant('CronTask::STATE_WAITING')): __('Scheduled'),
                                    (constant('CronTask::STATE_DISABLE')): __('Disabled')                                    
                                }, __('Status'), {
                                        required:  true
                                }) 
                            }}

							{{ fields.smallTitle('Schedule') }}

							<div class="form-field row align-items-center col-12 col-sm-6  mb-2">
								<label class="col-form-label col-xxl-5 text-xxl-end " for="saved_search_id">Saved Search
									<span class="required">*</span>
								</label>
								<div class="col-xxl-7  field-container" data-select2-id="16">
									{{ widgets['saved_search_id']|raw }}
								</div>
							</div>

							<div class="form-field row align-items-center col-12 col-sm-6  mb-2">
								<label class="col-form-label col-xxl-5 text-xxl-end " for="retention_period">Run frequency
									<span class="required">*</span>
								</label>
								<div class="col-xxl-7  field-container" data-select2-id="16">
									{{ widgets['frequency_dropdown']|raw }}
								</div>
							</div>

							<div class="form-field row align-items-center col-12 col-sm-6  mb-2">
								<label class="col-form-label col-xxl-5 text-xxl-end " for="retention_period">Number of days this reports are stored</label>
								<div class="col-xxl-7  field-container" data-select2-id="16">
									{{ widgets['retention_period']|raw }}
								</div>
							</div>

							<div class="form-field row align-items-center col-12 col-sm-6  mb-2">

								<label class="col-form-label col-xxl-5 text-xxl-end " for="uniqueness">{{ __('File Uniqueness', 'smartreport') }}
									<span class="required">*</span>
								</label>
								<div class="col-xxl-7  field-container">
									{{ widgets['uniqueness_dropdown']|raw }}
								</div>
							</div>

							<div class="form-field row align-items-center col-12 col-sm-6  mb-2">

								<label class="col-form-label col-xxl-5 text-xxl-end " for="retention_period">Email this report to</label>
								<div class="col-xxl-7  field-container" data-select2-id="16">
									{{ widgets['user_email']|raw }}
								</div>
							</div>

							{% if not item.isNewItem() %}
								<div
									class="row flex-row">
									{# Last run #}
									{% set last_run_field %}
									{% if item.fields['lastrun'] is empty %}
										{{ __('Never') }}
									{% else %}
										{{ item.fields['lastrun']|formatted_datetime }}
									{% endif %}
									{% endset %}
									{{ fields.htmlField('last_run', last_run_field, __('Last run'), {
                                            wrapper_class: 'form-control-plaintext ms-2'
                                        }) 
                                    }}

									{# Next run #}
									{% set launch = item.fields['state'] != constant('PluginSmartreportReportdefination::STATE_RUNNING') %}
									{% set next_run_field %}
									{% if item.fields['status'] != constant('PluginSmartreportReportdefination::STATE_WAITING') %}
										{{ item.getStateName(item.fields['status']) }}
									{% else %}
										{{ item_meta.next_run_display }}
									{% endif %}
									{% if config('maintenance_mode') %}
										<div class="alert alert-warning">
											{{ __('Maintenance mode enabled, running tasks is disabled') }}
										</div>
									{% elseif can_execute and launch %}
										<button class="btn btn-primary" type="submit" name="execute" value="{{ item.fields['name'] }}">{{ __('Execute') }}</button>
									{% endif %}

									{% if can_execute and item.fields['status'] == constant('PluginSmartreportReportdefination::STATE_RUNNING') %}
										<button class="btn btn-primary" type="submit" name="resetstate">
											<i class="ti ti-circle-x me-1"></i>
											{{ __('Blank') }}
										</button>
									{% endif %}
									{% endset %}
									{{ fields.htmlField('next_run', next_run_field, __('Next run'), {
                                            add_field_class: 'ms-0',
                                        }) 
                                    }}
								</div>
							{% endif %}

							{{ fields.smallTitle('Visibility') }}

							{{ fields.dropdownField('entity', 'entities_id', item.fields['entities_id'], __('Entity'), {
                                        required:  true
                                }) 
                            }}

							{{ fields.dropdownYesNo('is_recursive', item.fields['is_recursive'], __('Child entities'), {
                                        required:  true,
										add_field_class: 'text-xxl-start',
                                }) 
                            }}

						{% endblock %}
					</div>
				</div>
			</div>
		</div>
	</div>
</div>
